    "TOUR": {
      "name": "일반 투어/체험",
      "description": "PB Exclusive가 아닌 일반 투어 상품",
      "tier": "generic",
      "subtypes": [
        { "id": "GUIDED_TOUR", "name": "가이드 투어", "examples": "시내 워킹투어, 야경투어", "blockHint": "guideIntro 권장" },
        { "id": "EXPERIENCE", "name": "스냅·스파·미식", "examples": "스냅촬영, 온천 스파, 쿠킹클래스", "blockHint": "imageGrid 중심" },
        { "id": "SPECIAL", "name": "골프·특수투어", "examples": "골프, 다이빙, 스카이다이빙", "blockHint": "notice 블록 강조" }
