  "ordering": {
    "description": "블록 배치 순서 규칙. PB Exclusive는 실제 나오시마·구마모토 PDP 프레임 구조에서 추출.",

    "constraints": [
      {
        "rule": "exclusiveHeader는 반드시 첫 번째",
        "block": "exclusiveHeader",
        "position": "first",
        "appliesTo": ["PB_EXCLUSIVE"]
      },
      {
        "rule": "heroImage는 exclusiveHeader 직후",
        "block": "heroImage",
        "position": "second",
        "appliesTo": ["PB_EXCLUSIVE"],
        "note": "사이에 divider 삽입하지 않음"
      },
      {
        "rule": "trustPoints는 반드시 마지막",
        "block": "trustPoints",
        "position": "last",
        "appliesTo": ["PB_EXCLUSIVE"]
      },
      {
        "rule": "notice는 trustPoints 바로 앞",
        "block": "notice",
        "position": "before-last",
        "before": "trustPoints",
        "appliesTo": ["PB_EXCLUSIVE"]
      },
      {
        "rule": "includeExclude는 notice 직전 배치",
        "block": "includeExclude",
        "before": "notice",
        "note": "포함/불포함을 먼저 보여주고, 주의사항(notice)은 그 뒤에 배치"
      },
      {
        "rule": "introSection은 heroImage 직후",
        "block": "introSection",
        "after": "heroImage"
      },
      {
        "rule": "painPointCards는 introSection 직후",
        "block": "painPointCards",
        "after": "introSection",
        "appliesTo": ["PB_EXCLUSIVE"]
      },
      {
        "rule": "programCard 앞에 반드시 sectionHeader",
        "block": "programCard",
        "requiresBefore": "sectionHeader"
      }
    ],

    "recommendedOrder": {
      "PB_EXCLUSIVE": [
        "exclusiveHeader",
        "heroImage",
        "introSection",
        "painPointCards",
        "guideProfile",
        "recommendBox",
        "--- divider ---",
        "sectionHeader (프로그램 1)",
        "programCard (반복)",
        "--- divider ---",
        "sectionHeader (프로그램 2)",
        "programCard (반복)",
        "highlightCallout",
        "--- divider ---",
        "visualTimeline",
        "--- divider ---",
        "priceTable",
        "numberedList",
        "imageGrid",
        "includeExclude",
        "notice",
        "trustPoints"
      ],
      "TICKET": [
        "heroImage",
        "introSection",
        "numberedList",
        "imageGrid",
        "priceTable",
        "highlightCallout",
        "includeExclude",
        "notice"
      ],
      "TOUR": [
        "heroImage",
        "introSection",
        "numberedList",
        "imageGrid",
        "recommendBox",
        "sectionHeader",
        "highlightCallout",
        "includeExclude",
        "notice"
      ],
      "SEMI_PACKAGE": [
        "heroImage",
        "introSection",
        "packageOverview",
        "--- divider ---",
        "dayItinerary",
        "--- divider ---",
        "hotelInfo",
        "--- divider ---",
        "imageGrid",
        "highlightCallout",
        "--- divider ---",
        "priceTable",
        "numberedList",
        "--- divider ---",
        "faqAccordion",
        "includeExclude",
        "notice",
        "customerReview"
      ],
      "ACTIVITY": [
        "heroImage",
        "introSection (핵심 매력)",
        "introSection (두 번째 감성 훅, optional)",
        "imageGrid (체험 분위기 사진)",
        "--- divider ---",
        "visualTimeline (체험 시뮬레이션)",
        "--- divider ---",
        "highlightCallout (왜 이 상품?)",
        "sectionImage (마무리 감성)",
        "═══ Zone 전환 ═══",
        "operationTable (운영 정보)",
        "--- divider ---",
        "recommendBox",
        "--- divider ---",
        "includeExclude (포함/불포함)",
        "notice (주의사항)",
        "--- divider ---",
        "customerReview"
      ],
      "CONVENIENCE": [
        "heroImage",
        "introSection",
        "numberedList",
        "priceTable",
        "imageGrid",
        "includeExclude",
        "notice"
      ]
    }
  },

  "composition": {
    "description": "블록 간 조합 규칙",
    "rules": [
      {
        "name": "programCard 반복 사용",
        "block": "programCard",
        "maxInstances": 12,
        "note": "투어 프로그램의 각 스팟/활동마다 1장. 나오시마 8개, 구마모토 10개 사용 확인."
      },
      {
        "name": "sectionHeader 반복 사용",
        "block": "sectionHeader",
        "maxInstances": 5,
        "note": "programCard 그룹마다 앞에 1개씩. 프로그램 섹션 구분 용도."
      },
      {
        "name": "programCard 그룹핑",
        "blocks": ["sectionHeader", "programCard"],
        "rule": "sectionHeader 1개 + programCard N개가 하나의 프로그램 섹션을 구성",
        "note": "나오시마: '나오시마 워킹투어' 섹션 1개. 구마모토: '수향마을 산책' + '구마모토 시내 탐방' 2개 섹션."
      },
      {
        "name": "exclusiveHeader 사용",
        "block": "exclusiveHeader",
        "exactInstances": 1,
        "note": "PDP 최상단(heroImage 전). recommendedOrder에 맞춰 1회 사용.",
        "appliesTo": ["PB_EXCLUSIVE"]
      },
      {
        "name": "highlightCallout 위치 제한",
        "block": "highlightCallout",
        "maxInstances": 2,
        "note": "프로그램 카드 사이 또는 직후에 배치. 핵심 차별점 강조."
      },
      {
        "name": "visualTimeline 단독 사용",
        "block": "visualTimeline",
        "maxInstances": 1,
        "note": "하루 일정 전체를 한 블록으로 요약. programCard 그룹 이후에 배치."
      },
      {
        "name": "guideProfile 단독 사용",
        "block": "guideProfile",
        "maxInstances": 1,
        "note": "가이드 소개는 1회. introSection 이후, programCard 이전에 배치."
      },
      {
        "name": "painPointCards 단독 사용",
        "block": "painPointCards",
        "maxInstances": 1,
        "note": "고객 불안 해소 카드. introSection 직후 배치."
      },
      {
        "name": "trustPoints 단독 사용",
        "block": "trustPoints",
        "maxInstances": 1,
        "note": "PDP 최하단 신뢰 지표. 어두운 배경으로 마무리."
      },
      {
        "name": "generic 블록은 exclusive 블록 사이에 배치",
        "blocks": ["numberedList", "priceTable", "imageGrid", "notice"],
        "rule": "PB_EXCLUSIVE에서 사용 시, programCard 그룹과 trustPoints 사이에 배치",
        "enforcement": "warning"
      }
    ],
    "minimumBlocks": {
      "PB_EXCLUSIVE": 7,
      "TICKET": 3,
      "TOUR": 3,
      "ACTIVITY": 5,
      "SEMI_PACKAGE": 7,
      "CONVENIENCE": 3
    },
    "maximumBlocks": {
      "PB_EXCLUSIVE": 25,
      "TICKET": 10,
      "TOUR": 12,
      "ACTIVITY": 14,
      "SEMI_PACKAGE": 18,
      "CONVENIENCE": 8
    },
    "note": "PB Exclusive는 programCard 반복으로 블록 수가 많음. 나오시마 실제 PDP는 약 20개 블록."
  },

  "noDividerPairs": [
    ["exclusiveHeader", "heroImage"],
    ["heroImage", "introSection"]
  ],

  "deprecated": {
    "note": "v1.0.0에서 사용하던 블록 ID → v2.0.0 대응표",
    "mapping": {
      "hero": "heroImage",
      "titleParagraph": "introSection 또는 sectionHeader",
      "step": "visualTimeline",
      "fullbleed": "heroImage",
      "recommend": "recommendBox",
      "imageText": "guideProfile",
      "daySchedule": "visualTimeline"
    }
  }
}
