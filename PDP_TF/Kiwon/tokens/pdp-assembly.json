        "guideProfile"
      ]
    },
    "SEMI_PACKAGE": {
      "name": "세미패키지",
      "description": "호텔 포함 다일정 상품. packageOverview + Day별 일정 + 호텔 안내 + FAQ가 핵심 차별 섹션.",
      "tier": "generic",
      "example": "상하이 3박4일 (Figma 281:13219), 미서부 9박11일 (experiences.myrealtrip.com/products/3441658)",
      "required": [
        "heroImage",
        "introSection",
        "packageOverview",
        "dayItinerary",
        "hotelInfo",
        "numberedList",
        "priceTable"
      ],
      "recommended": [
        "faqAccordion",
        "imageGrid",
        "includeExclude",
        "notice",
        "customerReview",
        "highlightCallout"
      ],
      "optional": [
        "sectionHeader",
        "recommendBox",
        "guideIntro",
        "programCard",
        "visualTimeline"
      ],
      "notApplicable": [
        "exclusiveHeader",
        "painPointCards",
        "trustPoints",
        "guideProfile"
      ],
      "designNote": "surchargeTable은 priceTable의 행(싱글룸 추가요금)으로 흡수. 별도 블록 불필요."
    },
    "ACTIVITY": {
      "name": "액티비티/체험",
      "description": "쿠킹클래스, 스냅촬영, 스파, 다이빙, 스노클링 등 체험 상품. MRT 분류 ACTIVITY + CLASS 통합. v2: 감성 64% 구조로 재설계.",
      "tier": "generic",
      "mrtMapping": ["ACTIVITY", "CLASS"],
      "designNote": "CVR 분석 결과 ACTIVITY가 디자인 품질에 가장 민감 (9/9개월 양의 효과). Zone 1(욕망 65%) + Zone 2(확인 35%) 2-zone 구조. 임계점 7,000px+.",
      "required": [
        "heroImage",
        "introSection",
        "visualTimeline"
      ],
      "recommended": [
        "imageGrid",
        "highlightCallout",
        "operationTable",
        "recommendBox",
        "includeExclude",
        "notice",
        "customerReview"
      ],
      "optional": [
        "sectionHeader",
        "priceTable",
        "guideIntro"
      ],
      "notApplicable": [
        "exclusiveHeader",
        "painPointCards",
        "trustPoints",
        "guideProfile",
        "programCard",
        "numberedList"
      ],
      "zoneStructure": {
        "zone1_desire": {
          "description": "욕망 영역 — '이 체험을 하면 이런 경험을 할 수 있어요'",
          "targetRatio": "65%",
          "blocks": ["heroImage", "introSection", "introSection(2nd)", "imageGrid", "visualTimeline", "highlightCallout"]
        },
        "zone2_confirm": {
          "description": "확인 영역 — '사기로 했으니 이것만 확인하세요'",
          "targetRatio": "35%",
          "blocks": ["operationTable", "recommendBox", "notice", "customerReview"]
        }
      }
    },
    "CONVENIENCE": {
      "name": "편의/서비스",
      "description": "유심, 포켓와이파이, 수하물배송 등",
      "tier": "generic",
      "required": [
        "heroImage",
        "introSection",
        "numberedList"
      ],
      "recommended": [
        "priceTable",
        "includeExclude",
        "notice",
        "customerReview"
      ],
      "optional": [
        "imageGrid",
        "sectionHeader",
        "recommendBox",
        "highlightCallout"
      ],
      "notApplicable": [
        "exclusiveHeader",
        "painPointCards",
        "guideProfile",
        "guideIntro",
        "trustPoints",
        "visualTimeline",
        "programCard"
      ]
    }
