{
  "$meta": {
    "name": "PDP Assembly Rules",
    "version": "3.0.0",
    "blocks": "./pdp-blocks.json",
    "tokens": "./pdp-tokens.json",
    "updatedAt": "2026-03-11",
    "note": "v3: includeExclude 블록 추가. 포함/불포함을 notice에서 분리하여 전 카테고리 통일 마크업 적용."
  },

  "canvas": {
    "width": 390,
    "background": "#FFFFFF",
    "fontFamily": "'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, sans-serif"
  },

  "divider": {
    "type": "FRAME",
    "height": 8,
    "background": "#F1F3F5",
    "insertBetween": "sections",
    "note": "섹션 사이 자동 삽입. exclusiveHeader, heroImage 사이에는 삽입하지 않음."
  },

  "categories": {
    "PB_EXCLUSIVE": {
      "name": "PB Exclusive",
      "description": "PB 자체 기획 상품 — 워킹투어, 체험, 패키지 등. 기존 PB_TOUR + PB_PACKAGE 통합.",
      "tier": "exclusive",
      "required": [
        "exclusiveHeader",
        "heroImage",
        "introSection",
        "sectionHeader",
        "programCard",
        "trustPoints"
      ],
      "recommended": [
        "painPointCards",
        "guideProfile",
        "recommendBox",
        "visualTimeline",
        "highlightCallout",
        "priceTable",
        "includeExclude",
        "notice"
      ],
      "optional": [
        "numberedList",
        "imageGrid",
        "customerReview"
      ],
      "notApplicable": [
        "guideIntro"
      ]
    },
    "TICKET": {
      "name": "티켓/입장권",
