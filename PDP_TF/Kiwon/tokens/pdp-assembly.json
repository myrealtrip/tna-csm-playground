      "tier": "generic",
      "subtypes": [
        { "id": "THEME_PARK", "name": "테마파크", "examples": "USJ, 디즈니, 해리포터 스튜디오" },
        { "id": "TRANSPORT", "name": "교통", "examples": "JR패스, 이코카, 스이카" },
        { "id": "CITY_PASS", "name": "시티패스", "examples": "오사카 주유패스, 도쿄 서브웨이 패스" },
        { "id": "CRUISE_SHOW", "name": "유람선·공연", "examples": "하롱베이 크루즈, 쇼 입장권" }
      ],
      "subtypeNote": "서브타입 간 블록 조합 차이 없음. 상품 분류·검색 용도로만 구분.",
      "required": [
